{
  "name": "orra",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/dashboard\" \"npm run dev --workspace=apps/api-gateway\" \"npm run dev --workspace=services/voice\" \"npm run dev --workspace=services/llm\" \"npm run dev --workspace=services/retrieval\" \"npm run dev --workspace=services/lead\"",
    "build": "npm run build --workspace=apps/dashboard",
    "db:push": "npm run db:push --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.11",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "concurrently": "^8.2.0",
    "daisyui": "^5.6.13",
    "lucide-react": "^1.23.0",
    "postcss": "^8.5.16",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2"
  }
}
